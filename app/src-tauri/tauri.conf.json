{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoloPDF",
  "version": "0.1.0",
  "identifier": "app.solopdf",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SoloPDF",
        "width": 1240,
        "height": 840,
        "minWidth": 520,
        "minHeight": 400,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "mainBinaryName": "SoloPDF",
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "license": "MIT",
    "publisher": "alexlee",
    "homepage": "https://doaipm.com/solopdf/",
    "shortDescription": "Free, ad-free, local-first PDF reader",
    "longDescription": "SoloPDF is a free, ad-free, local-first PDF reader. Highlights become Markdown notes that SoloMD can open, search, and version.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["solopdf"]
      }
    }
  }
}
